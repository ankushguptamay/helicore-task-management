{
  "name": "law-wheels-node",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon src/index.js",
    "start": "cross-env NODE_ENV=production node src/index.js",
    "migration:generate": "npx sequelize-cli migration:generate --name",
    "migration:run": "cross-env NODE_ENV=development npx sequelize-cli db:migrate",
    "migration:undo": "cross-env NODE_ENV=development npx sequelize-cli db:migrate:undo",
    "migration:run:prod": "cross-env NODE_ENV=production npx sequelize-cli db:migrate",
    "migration:undo:prod": "cross-env NODE_ENV=production npx sequelize-cli db:migrate:undo",
    "seed:generate": "npx sequelize-cli seed:generate --name",
    "seed:run": "cross-env NODE_ENV=development npx sequelize-cli db:seed:all",
    "seed:run:prod": "cross-env NODE_ENV=production npx sequelize-cli db:seed:all"
  },
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "helmet": "^8.1.0",
    "joi": "^17.7.0",
    "jsonwebtoken": "^9.0.1",
    "mysql2": "^2.3.3",
    "redis": "^5.11.0",
    "sequelize": "^6.25.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "sequelize-cli": "^6.6.5"
  }
}
